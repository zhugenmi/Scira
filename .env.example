# Scira Environment Configuration Template
# Copy this file to .env and fill in your values

# ===========================================
# LLM Provider Configuration
# ===========================================
# Supported providers: openai, anthropic, custom
LLM_PROVIDER=openai

# Model configuration
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# API Key (required based on provider)
# For OpenAI: use OPENAI_API_KEY
# For Anthropic: use ANTHROPIC_API_KEY
OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# Advanced API Configuration (Optional)
# ===========================================
# Custom API base URL (for compatible APIs like Azure, local models, etc.)
# Example: LLM_BASE_URL=https://api.openai.com/v1
# Example: LLM_BASE_URL=http://localhost:8000/v1
LLM_BASE_URL=

# API version (for Azure OpenAI)
LLM_API_VERSION=2024-02-01

# Request settings
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ===========================================
# LangSmith Tracing (Optional)
# ===========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_langsmith_api_key
LANGCHAIN_PROJECT=scira-research-agent

# ===========================================
# Scira Behavior Settings
# ===========================================
# Set to true to skip human approval steps (automated mode)
AUTO_APPROVE=false

# Maximum number of literature papers to process
MAX_LITERATURE_COUNT=20

# Maximum number of PDFs to download per search
MAX_PDF_DOWNLOAD=10


# ===========================================
# Paper-Search-Mcp Configuration
# ===========================================
# paper-search-mcp unified environment configuration
# Preferred format: PAPER_SEARCH_MCP_<NAME>

# Core optional keys/tokens
PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=
PAPER_SEARCH_MCP_CORE_API_KEY=
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
PAPER_SEARCH_MCP_DOAJ_API_KEY=
PAPER_SEARCH_MCP_ZENODO_ACCESS_TOKEN=
PAPER_SEARCH_MCP_GOOGLE_SCHOLAR_PROXY_URL=

# Optional provider-specific keys
PAPER_SEARCH_MCP_OPENAIRE_API_KEY=
PAPER_SEARCH_MCP_CITESEERX_API_KEY=
PAPER_SEARCH_MCP_IEEE_API_KEY=
PAPER_SEARCH_MCP_ACM_API_KEY=

# Optional: override env file path if needed
# PAPER_SEARCH_MCP_ENV_FILE=/absolute/path/to/.env

# Backward compatibility:
# legacy names without PAPER_SEARCH_MCP_ prefix are still supported.

# Paper Download Settings
PAPER_DOWNLOAD_DIR=./downloads

# ===========================================
# Memory & Context Management
# ===========================================
MAX_CONTEXT_TOKENS=100000
CONTEXT_COMPRESSION_THRESHOLD=0.8
COMPRESSION_KEEP_RECENT=5
# ===========================================
# Logging & Metrics
# ===========================================
# 日志级别：TRACE/DEBUG/INFO/SUCCESS/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO
# 日志文件格式：text（默认，可读）或 json（结构化，便于接入 ELK/Loki）
LOG_FORMAT=text
# 详细模式（覆盖 LOG_LEVEL 为 DEBUG）
LOG_VERBOSE=0
